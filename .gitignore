### --- Python Environment --- ###
# Ignore the virtual environment (everyone should create their own)
venv/
.venv/
env/
bin/
lib64/

# Python cache files
__pycache__/
*.py[cod]
*$py.class
.ruff_cache/

### --- Data & Large Files --- ###
data/raw/
data/processed/
*.csv
*.json
*.parquet
*.zip
